FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-pip python3-venv \
    openssh-client sshpass \
    git curl ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Install ansible into a virtualenv (avoid PEP 668 externally-managed error)
RUN python3 -m venv /opt/ansible-venv \
    && /opt/ansible-venv/bin/pip install --no-cache-dir -U pip setuptools wheel \
    && /opt/ansible-venv/bin/pip install --no-cache-dir "ansible==9.*" passlib

# Make venv the default python/pip/ansible on PATH
ENV PATH="/opt/ansible-venv/bin:$PATH"

WORKDIR /work
